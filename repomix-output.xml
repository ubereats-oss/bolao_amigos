    } else if (posicao == 2) {
      return const Text('🥈', style: TextStyle(fontSize: 28));
    } else if (posicao == 3) {
      return const Text('🥉', style: TextStyle(fontSize: 28));
    }
    return SizedBox(
      width: 36,
      child: Text(
        '$posicao°',
        textAlign: TextAlign.center,
        style: const TextStyle(
            fontWeight: FontWeight.bold, color: Colors.grey),
      ),
    );
  }
}
