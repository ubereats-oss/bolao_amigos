110:   Future<void> _parsearPlanilha(Uint8List bytes) async {
111:     setState(() => _loading = true);
112:     try {
113:       final ex = Excel.decodeBytes(bytes);
114:       final sheet = ex.tables['Grupos'];
115:       if (sheet == null) {
116:         setState(() => _loading = false);
117:         if (mounted) _mostrarErro('Aba "Grupos" não encontrada na planilha.');
118:         return;
119:       }
120:       final lk = {for (final m in _matches) '${m.homeTeamId}|${m.awayTeamId}': m};
121:       final res = <ResultadoImportado>[];
122:       for (final row in sheet.rows) {
123:         _processarBloco(row, 8, 3, 7, 13, 9, lk, res);
124:         _processarBloco(row, 21, 16, 20, 26, 22, lk, res);
125:       }
126:       setState(() { _resultados = res; _loading = false; });
127:     } catch (_) {
