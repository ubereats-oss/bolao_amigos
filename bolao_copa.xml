<file path="lib/features/auth/login_screen.dart">
  1: import 'package:flutter/foundation.dart';
  2: import 'package:flutter/material.dart';
  3: import 'package:sign_in_with_apple/sign_in_with_apple.dart';
  4: import '../../services/auth_service.dart';
  5: import '../../core/routes/app_routes.dart';
  6: import '../../core/widgets/sobre_dialog.dart';
  7: 
  8: class LoginScreen extends StatefulWidget {
  9:   const LoginScreen({super.key});
 10:   @override
 11:   State<LoginScreen> createState() => _LoginScreenState();
 12: }
 13: 
 14: class _LoginScreenState extends State<LoginScreen> {
 15:   final _formKey = GlobalKey<FormState>();
 16:   final _emailController = TextEditingController();
 17:   final _passwordController = TextEditingController();
 18:   final _authService = AuthService();
 19:   bool _loading = false;
 20:   bool _senhaVisivel = false;
 21:   String? _erro;
 22: 
 23:   @override
 24:   void dispose() {
 25:     _emailController.dispose();
 26:     _passwordController.dispose();
 27:     super.dispose();
 28:   }
 29: 
 30:   Future<void> _loginEmail() async {
 31:     if (!_formKey.currentState!.validate()) return;
 32:     setState(() {
 33:       _loading = true;
 34:       _erro = null;
 35:     });
 36:     try {
 37:       await _authService.signInWithEmail(
 38:         _emailController.text,
 39:         _passwordController.text,
 40:       );
 41:       if (mounted) Navigator.pushReplacementNamed(context, '/groups');
 42:     } on Exception catch (e) {
 43:       setState(() {
 44:         _erro = _traduzirErro(e.toString());
 45:       });
 46:     } finally {
 47:       if (mounted) {
 48:         setState(() {
 49:           _loading = false;
 50:         });
 51:       }
 52:     }
 53:   }
 54: 
 55:   Future<void> _loginGoogle() async {
 56:     setState(() {
 57:       _loading = true;
 58:       _erro = null;
 59:     });
 60:     try {
 61:       final result = await _authService.signInWithGoogle();
 62:       if (result != null && mounted) {
 63:         Navigator.pushReplacementNamed(context, '/groups');
 64:       }
 65:     } on Exception catch (e) {
 66:       setState(() {
 67:         _erro = _traduzirErro(e.toString());
 68:       });
 69:     } finally {
 70:       if (mounted) {
 71:         setState(() {
 72:           _loading = false;
 73:         });
 74:       }
 75:     }
 76:   }
 77: 
 78:   Future<void> _loginApple() async {
 79:     setState(() {
 80:       _loading = true;
 81:       _erro = null;
 82:     });
 83:     try {
 84:       await _authService.signInWithApple();
 85:       if (mounted) {
 86:         Navigator.pushReplacementNamed(context, '/groups');
 87:       }
 88:     } on SignInWithAppleAuthorizationException catch (e) {
 89:       if (e.code == AuthorizationErrorCode.canceled) {
 90:         if (mounted) setState(() => _loading = false);
 91:         return;
 92:       }
 93:       final msg = switch (e.code) {
 94:         AuthorizationErrorCode.failed =>
 95:           'Falha na autenticação com Apple. Verifique as configurações da sua conta.',
 96:         AuthorizationErrorCode.invalidResponse =>
 97:           'Resposta inválida da Apple. Tente novamente.',
 98:         AuthorizationErrorCode.notHandled =>
 99:           'Autenticação Apple não pôde ser concluída. Tente novamente.',
100:         AuthorizationErrorCode.unknown =>
101:           'Erro desconhecido na autenticação Apple. Tente novamente.',
102:         _ => 'Erro ao entrar com Apple: ${e.message}',
103:       };
104:       if (mounted) setState(() => _erro = msg);
105:     } on Exception catch (e) {
106:       if (mounted) setState(() => _erro = _traduzirErro(e.toString()));
107:     } finally {
108:       if (mounted) setState(() => _loading = false);
109:     }
110:   }
111: 
112:   String _traduzirErro(String erro) {
113:     const map = {
114:       'user-not-found': 'Usuário não encontrado.',
115:       'wrong-password': 'Senha incorreta.',
116:       'invalid-email': 'E-mail inválido.',
117:       'invalid-credential': 'E-mail ou senha incorretos.',
118:       'too-many-requests': 'Muitas tentativas. Tente mais tarde.',
119:     };
120:     for (final entry in map.entries) {
121:       if (erro.contains(entry.key)) {
122:         return entry.value;
123:       }
124:     }
125:     return 'Erro ao entrar. Tente novamente.';
126:   }
127: 
128:   Future<void> _recuperarSenha() async {
129:     final emailCtrl = TextEditingController(text: _emailController.text.trim());
130:     await showDialog(
131:       context: context,
132:       builder: (ctx) => AlertDialog(
133:         title: const Text('Recuperar senha'),
134:         content: Column(
135:           mainAxisSize: MainAxisSize.min,
136:           children: [
137:             const Text(
138:                 'Informe seu e-mail para receber o link de redefinição.'),
139:             const SizedBox(height: 16),
140:             TextFormField(
141:               controller: emailCtrl,
142:               keyboardType: TextInputType.emailAddress,
143:               decoration: const InputDecoration(
144:                 labelText: 'E-mail',
145:                 border: OutlineInputBorder(),
146:                 prefixIcon: Icon(Icons.email_outlined),
147:               ),
148:             ),
149:           ],
150:         ),
151:         actions: [
152:           TextButton(
153:             onPressed: () => Navigator.pop(ctx),
154:             child: const Text('Cancelar'),
155:           ),
156:           FilledButton(
157:             onPressed: () async {
158:               final email = emailCtrl.text.trim();
159:               if (email.isEmpty) return;
160:               try {
161:                 await _authService.sendPasswordReset(email);
162:                 if (ctx.mounted) {
163:                   Navigator.pop(ctx);
164:                   ScaffoldMessenger.of(ctx).showSnackBar(
165:                     const SnackBar(
166:                       content: Text('E-mail de recuperação enviado!'),
167:                       backgroundColor: Color(0xFF1A6B3C),
168:                     ),
169:                   );
170:                 }
171:               } on Exception {
172:                 if (ctx.mounted) {
173:                   ScaffoldMessenger.of(ctx).showSnackBar(
174:                     const SnackBar(
175:                       content: Text(
176:                           'Não foi possível enviar o e-mail. Verifique o endereço.'),
177:                       backgroundColor: Colors.red,
178:                     ),
179:                   );
180:                 }
181:               }
182:             },
183:             child: const Text('Enviar'),
184:           ),
185:         ],
186:       ),
187:     );
188:     emailCtrl.dispose();
189:   }
190: 
191:   @override
192:   Widget build(BuildContext context) {
193:     return Scaffold(
194:       body: Stack(
195:         children: [
196:           SafeArea(
197:             child: Center(
198:               child: SingleChildScrollView(
199:                 padding: const EdgeInsets.all(32),
200:                 child: Form(
201:                   key: _formKey,
202:                   child: Column(
203:                     mainAxisAlignment: MainAxisAlignment.center,
204:                     children: [
205:                       const Icon(Icons.emoji_events,
206:                           size: 80, color: Color(0xFF1A6B3C)),
207:                       const SizedBox(height: 16),
208:                       const Text(
209:                         'Bolão com Amigos',
210:                         style: TextStyle(
211:                           fontSize: 24,
212:                           fontWeight: FontWeight.bold,
213:                         ),
214:                       ),
215:                       const SizedBox(height: 40),
216:                       TextFormField(
217:                         controller: _emailController,
218:                         keyboardType: TextInputType.emailAddress,
219:                         decoration: const InputDecoration(
220:                           labelText: 'E-mail',
221:                           border: OutlineInputBorder(),
222:                           prefixIcon: Icon(Icons.email_outlined),
223:                         ),
224:                         validator: (v) =>
225:                             v == null || v.isEmpty ? 'Informe o e-mail' : null,
226:                       ),
227:                       const SizedBox(height: 16),
228:                       TextFormField(
229:                         controller: _passwordController,
230:                         obscureText: !_senhaVisivel,
231:                         decoration: InputDecoration(
232:                           labelText: 'Senha',
233:                           border: const OutlineInputBorder(),
234:                           prefixIcon: const Icon(Icons.lock_outline),
235:                           suffixIcon: IconButton(
236:                             icon: Icon(
237:                               _senhaVisivel
238:                                   ? Icons.visibility_off_outlined
239:                                   : Icons.visibility_outlined,
240:                             ),
241:                             onPressed: () =>
242:                                 setState(() => _senhaVisivel = !_senhaVisivel),
243:                           ),
244:                         ),
245:                         validator: (v) =>
246:                             v == null || v.isEmpty ? 'Informe a senha' : null,
247:                       ),
248:                       if (_erro != null) ...[
249:                         const SizedBox(height: 12),
250:                         Text(_erro!, style: const TextStyle(color: Colors.red)),
251:                       ],
252:                       const SizedBox(height: 24),
253:                       SizedBox(
254:                         width: double.infinity,
255:                         child: FilledButton(
256:                           onPressed: _loading ? null : _loginEmail,
257:                           child: _loading
258:                               ? const SizedBox(
259:                                   height: 20,
260:                                   width: 20,
261:                                   child: CircularProgressIndicator(
262:                                       strokeWidth: 2, color: Colors.white),
263:                                 )
264:                               : const Text('Entrar'),
265:                         ),
266:                       ),
267:                       const SizedBox(height: 12),
268:                       SizedBox(
269:                         width: double.infinity,
270:                         child: OutlinedButton.icon(
271:                           onPressed: _loading ? null : _loginGoogle,
272:                           icon: const Icon(Icons.login),
273:                           label: const Text('Entrar com Google'),
274:                         ),
275:                       ),
276:                       if (defaultTargetPlatform == TargetPlatform.iOS) ...[
277:                         const SizedBox(height: 12),
278:                         SizedBox(
279:                           width: double.infinity,
280:                           child: SignInWithAppleButton(
281:                             onPressed: _loading ? () {} : _loginApple,
282:                             style: SignInWithAppleButtonStyle.black,
283:                             borderRadius: const BorderRadius.all(
284:                               Radius.circular(8),
285:                             ),
286:                           ),
287:                         ),
288:                       ],
289:                       const SizedBox(height: 24),
290:                       TextButton(
291:                         onPressed: () =>
292:                             Navigator.pushNamed(context, AppRoutes.register),
293:                         child: const Text('Não tem conta? Cadastre-se'),
294:                       ),
295:                       TextButton(
296:                         onPressed: _recuperarSenha,
297:                         child: const Text('Esqueci minha senha'),
298:                       ),
299:                     ],
300:                   ),
301:                 ),
302:               ),
303:             ),
304:           ),
305:           Positioned(
306:             top: 8,
307:             right: 8,
308:             child: SafeArea(
309:               child: IconButton(
310:                 icon: const Icon(Icons.info_outline, color: Color(0xFF1A6B3C)),
311:                 tooltip: 'Sobre',
312:                 onPressed: () async => mostrarSobre(context),
313:               ),
314:             ),
315:           ),
316:         ],
317:       ),
318:     );
319:   }
320: }
