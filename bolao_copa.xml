<file path="lib/data/repositories/match_repository.dart">
  1: import 'package:cloud_firestore/cloud_firestore.dart';
  2: import '../models/match.dart';
  3: import '../models/team.dart';
  4: 
  5: class MatchRepository {
  6:   final FirebaseFirestore _db = FirebaseFirestore.instance;
  7:   // Cache em memória por copa
  8:   static final Map<String, List<Match>> _groupMatchesCache = {};
  9:   static final Map<String, List<Match>> _knockoutMatchesCache = {};
 10:   static final Map<String, Map<String, Team>> _teamsCache = {};
 11:   static void clearCache() {
 12:     _groupMatchesCache.clear();
 13:     _knockoutMatchesCache.clear();
 14:     _teamsCache.clear();
 15:   }
 16: 
 17:   Future<List<Match>> fetchGroupMatches(String cupId,
 18:       {bool forceRefresh = false}) async {
 19:     if (!forceRefresh && _groupMatchesCache.containsKey(cupId)) {
 20:       return _groupMatchesCache[cupId]!;
 21:     }
 22:     final groupsSnapshot =
 23:         await _db.collection('cups').doc(cupId).collection('groups').get();
 24:     final List<Match> matches = [];
 25:     for (final groupDoc in groupsSnapshot.docs) {
 26:       final matchesSnapshot = await _db
 27:           .collection('cups')
 28:           .doc(cupId)
 29:           .collection('groups')
 30:           .doc(groupDoc.id)
 31:           .collection('matches')
 32:           .get();
 33:       for (final doc in matchesSnapshot.docs) {
 34:         final data = doc.data()
 35:           ..['group_id'] = groupDoc.id.toLowerCase()
 36:           ..['home_team_id'] = (doc.data()['home_team_id'] ?? '').toString().toLowerCase()
 37:           ..['away_team_id'] = (doc.data()['away_team_id'] ?? '').toString().toLowerCase();
 38:         matches.add(Match.fromFirestore(doc.id, data));
 39:       }
 40:     }
 41:     matches.sort((a, b) => a.matchTime.compareTo(b.matchTime));
 42:     _groupMatchesCache[cupId] = matches;
 43:     return matches;
 44:   }
 45: 
 46:   Future<List<Match>> fetchKnockoutMatches(String cupId,
 47:       {bool forceRefresh = false}) async {
 48:     if (!forceRefresh && _knockoutMatchesCache.containsKey(cupId)) {
 49:       return _knockoutMatchesCache[cupId]!;
 50:     }
 51:     final snapshot = await _db
 52:         .collection('cups')
 53:         .doc(cupId)
 54:         .collection('knockout_matches')
 55:         .get();
 56:     final matches = snapshot.docs
 57:         .map((doc) => Match.fromFirestore(doc.id, doc.data()))
 58:         .toList();
 59:     matches.sort((a, b) => a.matchTime.compareTo(b.matchTime));
 60:     _knockoutMatchesCache[cupId] = matches;
 61:     return matches;
 62:   }
 63: 
 64:   Future<Match?> fetchMatch(
 65:       String cupId, String matchId, String? groupId) async {
 66:     DocumentSnapshot doc;
 67:     if (groupId != null) {
 68:       doc = await _db
 69:           .collection('cups')
 70:           .doc(cupId)
 71:           .collection('groups')
 72:           .doc(groupId)
 73:           .collection('matches')
 74:           .doc(matchId)
 75:           .get();
 76:     } else {
 77:       doc = await _db
 78:           .collection('cups')
 79:           .doc(cupId)
 80:           .collection('knockout_matches')
 81:           .doc(matchId)
 82:           .get();
 83:     }
 84:     if (!doc.exists) return null;
 85:     return Match.fromFirestore(doc.id, doc.data() as Map<String, dynamic>);
 86:   }
 87: 
 88:   Future<Map<String, Team>> fetchTeams(String cupId,
 89:       {bool forceRefresh = false}) async {
 90:     if (!forceRefresh && _teamsCache.containsKey(cupId)) {
 91:       return _teamsCache[cupId]!;
 92:     }
 93:     final snapshot =
 94:         await _db.collection('cups').doc(cupId).collection('teams').get();
 95:     final teams = {
 96:       for (final doc in snapshot.docs)
 97:         doc.id: Team.fromFirestore(doc.id, doc.data())
 98:     };
 99:     _teamsCache[cupId] = teams;
100:     return teams;
101:   }
102: }
</file>

