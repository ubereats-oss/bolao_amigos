 18: class RankingScreen extends StatefulWidget {
 19:   final String groupId;
 20: 
 21:   const RankingScreen({super.key, required this.groupId});
 22: 
 23:   @override
 24:   State<RankingScreen> createState() => _RankingScreenState();
 25: }
 26: 
 27: class _RankingScreenState extends State<RankingScreen> {
 28:   final _authService = AuthService();
 29:   final Map<String, AppUser?> _userCache = {};
 30: 
 31:   List<_RankingEntry> _entries = [];
 32:   bool _loading = true;
 33:   String? _currentUid;
 34:   StreamSubscription<QuerySnapshot>? _subscription;
 35: 
 36:   @override
 37:   void initState() {
 38:     super.initState();
 39:     _currentUid = FirebaseAuth.instance.currentUser?.uid;
 40:     _subscription = FirebaseFirestore.instance
 41:         .collection('bolao_groups')
 42:         .doc(widget.groupId)
 43:         .collection('members')
 44:         .orderBy('points', descending: true)
 45:         .snapshots()
 46:         .listen(
 47:           _onSnapshot,
 48:           onError: (_) {
 49:             if (mounted) setState(() => _loading = false);
 50:           },
 51:         );
 52:   }
 53: 
 54:   @override
 55:   void dispose() {
 56:     _subscription?.cancel();
 57:     super.dispose();
 58:   }
 59: 
 60:   Future<void> _onSnapshot(QuerySnapshot snap) async {
 61:     final members = snap.docs
 62:         .map((d) =>
 63:             BolaoMember.fromFirestore(d.id, d.data() as Map<String, dynamic>))
 64:         .toList();
 65: 
 66:     final entries = await Future.wait(
 67:       members.map((m) async {
 68:         _userCache[m.userId] ??= await _authService.fetchAppUser(m.userId);
 69:         return _RankingEntry(member: m, user: _userCache[m.userId]);
 70:       }),
 71:     );
 72: 
 73:     if (mounted) {
 74:       setState(() {
 75:         _entries = entries;
 76:         _loading = false;
 77:       });
 78:     }
 79:   }
 80: 
 81:   @override
 82:   Widget build(BuildContext context) {
 83:     return Scaffold(
 84:       appBar: AppBar(
 85:         title: const Text('Ranking'),
 86:         backgroundColor: const Color(0xFF1A6B3C),
 87:         foregroundColor: Colors.white,
 88:       ),
 89:       body: _loading
 90:           ? const Center(child: CircularProgressIndicator())
 91:           : _entries.isEmpty
 92:               ? const Center(child: Text('Nenhum participante ainda.'))
 93:               : ListView.builder(
 94:                   padding: const EdgeInsets.symmetric(vertical: 8),
 95:                   itemCount: _entries.length,
 96:                   itemBuilder: (context, index) {
 97:                     final entry = _entries[index];
 98:                     final posicao = index + 1;
 99:                     final isMe = entry.member.userId == _currentUid;
100: 
101:                     return Container(
102:                       margin: const EdgeInsets.symmetric(
103:                           horizontal: 12, vertical: 4),
104:                       decoration: BoxDecoration(
105:                         color: isMe
106:                             ? const Color(0xFF1A6B3C).withValues(alpha: 0.08)
107:                             : null,
108:                         borderRadius: BorderRadius.circular(12),
109:                       ),
110:                       child: ListTile(
111:                         leading: _PosicaoWidget(posicao: posicao),
112:                         title: Text(
113:                           entry.name,
114:                           style: TextStyle(
115:                             fontWeight: isMe
116:                                 ? FontWeight.bold
117:                                 : FontWeight.normal,
118:                           ),
119:                         ),
120:                         subtitle: isMe
121:                             ? const Text(
122:                                 'Você',
123:                                 style: TextStyle(
124:                                     color: Color(0xFF1A6B3C), fontSize: 12),
125:                               )
126:                             : null,
127:                         trailing: Text(
128:                           '${entry.member.points} pts',
129:                           style: const TextStyle(
130:                             fontWeight: FontWeight.bold,
131:                             fontSize: 16,
132:                           ),
133:                         ),
134:                       ),
135:                     );
136:                   },
137:                 ),
138:     );
139:   }
140: }
141: 
142: class _PosicaoWidget extends StatelessWidget {
