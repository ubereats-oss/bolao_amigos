 53:         _matchRepo.fetchGroupMatches(cup.id, forceRefresh: forceRefresh),
 54:         _matchRepo.fetchKnockoutMatches(cup.id, forceRefresh: forceRefresh),
 55:         _matchRepo.fetchTeams(cup.id, forceRefresh: forceRefresh),
 56:       ]);
 57:       final group = results[0] as List<Match>;
 58:       final knockout = results[1] as List<Match>;
 59:       setState(() {
 60:         _matches = [...group, ...knockout]
 61:           ..sort((a, b) => a.matchTime.compareTo(b.matchTime));
 62:         _teams = results[2] as Map<String, Team>;
 63:         _loading = false;
 64:       });
 65:     } catch (_) {
