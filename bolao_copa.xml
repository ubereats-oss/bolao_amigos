 40:   Future<void> _carregar({bool forceRefresh = false}) async {
 41:     try {
 42:       final cup =
 43:           await _firestoreService.fetchActiveCup(forceRefresh: forceRefresh);
 44:       if (cup == null) {
 45:         setState(() {
 46:           _erro = 'Nenhum bolão ativo encontrado.';
 47:           _loading = false;
 48:         });
 49:         return;
 50:       }
