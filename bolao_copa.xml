<file path="lib/features/matches/knockout_bracket_screen.dart">
  1: import 'package:flutter/material.dart';
  2: import 'package:flutter/foundation.dart';
  3: import 'package:firebase_auth/firebase_auth.dart';
  4: import '../../core/constants/bracket_data.dart';
  5: import '../../data/models/cup.dart';
  6: import '../../data/models/match.dart';
  7: import '../../data/models/team.dart';
  8: import '../../data/models/knockout_prediction.dart';
  9: import '../../data/repositories/knockout_prediction_repository.dart';
 10: import 'bracket_engine.dart';
 11: import 'widgets/bracket_match_card.dart';
 12: 
 13: class KnockoutBracketScreen extends StatefulWidget {
 14:   final Cup cup;
 15:   final List<Match> groupMatches;
 16:   // null = sem palpite salvo para aquele jogo
 17:   final Map<String, List<int>?> groupPredictions;
 18:   final Map<String, Team> teams;
 19: 
 20:   const KnockoutBracketScreen({
 21:     super.key,
 22:     required this.cup,
 23:     required this.groupMatches,
 24:     required this.groupPredictions,
 25:     required this.teams,
 26:   });
 27: 
 28:   @override
 29:   State<KnockoutBracketScreen> createState() => _KnockoutBracketScreenState();
 30: }
 31: 
 32: class _KnockoutBracketScreenState extends State<KnockoutBracketScreen>
 33:     with SingleTickerProviderStateMixin {
 34:   final _knockoutRepo = KnockoutPredictionRepository();
 35: 
 36:   late TabController _tabController;
 37: 
 38:   Map<String, KnockoutPrediction> _koPreds = {};
 39:   final Map<String, List<int>> _localPalpites = {};
 40:   final Map<String, bool> _saving = {};
 41:   bool _savingAll = false;
 42:   bool _loading = true;
 43:   String? _erro;
 44:   List<ResolvedMatch> _resolved = [];
 45:   Map<String, List<String>> _groupTeams = {};
 46: 
 47:   static const List<String> _tabPhases = ['r32', 'r16', 'qf', 'sf', 'final'];
 48: 
 49:   @override
 50:   void initState() {
 51:     super.initState();
 52:     _tabController = TabController(length: _tabPhases.length, vsync: this);
 53:     _inicializar();
 54:   }
 55: 
 56:   @override
 57:   void dispose() {
 58:     _tabController.dispose();
 59:     super.dispose();
 60:   }
 61: 
 62:   @override
 63:   void didUpdateWidget(KnockoutBracketScreen oldWidget) {
 64:     super.didUpdateWidget(oldWidget);
 65:     if (!mapEquals(oldWidget.groupPredictions, widget.groupPredictions)) {
 66:       _recomputar();
 67:     }
 68:   }
 69: 
 70:   Future<void> _inicializar() async {
 71:     try {
 72:       final uid = FirebaseAuth.instance.currentUser!.uid;
 73:       final koPreds = await _knockoutRepo.fetchAll(uid);
 74: 
 75:       final Map<String, List<String>> groupTeams = {};
 76:       for (final m in widget.groupMatches) {
 77:         if (m.groupId == null) continue;
 78:         groupTeams.putIfAbsent(m.groupId!, () => []);
 79:         if (!groupTeams[m.groupId]!.contains(m.homeTeamId)) {
 80:           groupTeams[m.groupId]!.add(m.homeTeamId);
 81:         }
 82:         if (!groupTeams[m.groupId]!.contains(m.awayTeamId)) {
 83:           groupTeams[m.groupId]!.add(m.awayTeamId);
 84:         }
 85:       }
 86: 
 87:       final Map<String, List<int>> localPalpites = {};
 88:       for (final def in BracketData.allMatches) {
 89:         final saved = koPreds[def.id];
 90:         localPalpites[def.id] =
 91:             saved != null ? [saved.homeGoals, saved.awayGoals] : [0, 0];
 92:       }
 93: 
 94:       setState(() {
 95:         _koPreds = koPreds;
 96:         _groupTeams = groupTeams;
 97:         _localPalpites.addAll(localPalpites);
 98:         _loading = false;
 99:       });
100: 
101:       _recomputar();
102:     } catch (_) {
103:       setState(() {
104:         _erro = 'Erro ao carregar mata-mata.';
105:         _loading = false;
106:       });
107:     }
108:   }
109: 
110:   void _recomputar() {
111:     final engine = BracketEngine(
112:       groupMatches: widget.groupMatches,
113:       groupPredictions: widget.groupPredictions,
114:       knockoutPredictions: _koPreds,
115:       groupTeams: _groupTeams,
116:     );
117:     setState(() {
118:       _resolved = engine.resolveAll();
119:     });
120:   }
121: 
122:   void _incrementar(String slotId, int side) {
123:     if (widget.cup.isLocked) return;
124:     setState(() {
125:       _localPalpites[slotId]![side] =
126:           (_localPalpites[slotId]![side] + 1).clamp(0, 99);
127:     });
128:   }
129: 
130:   void _decrementar(String slotId, int side) {
131:     if (widget.cup.isLocked) return;
132:     setState(() {
133:       _localPalpites[slotId]![side] =
134:           (_localPalpites[slotId]![side] - 1).clamp(0, 99);
135:     });
136:   }
137: 
138:   Future<void> _salvar(ResolvedMatch rm) async {
139:     final uid = FirebaseAuth.instance.currentUser!.uid;
140:     setState(() => _saving[rm.def.id] = true);
141:     try {
142:       final gols = _localPalpites[rm.def.id]!;
143:       final pred = KnockoutPrediction(
144:         slotId: rm.def.id,
145:         userId: uid,
146:         homeGoals: gols[0],
147:         awayGoals: gols[1],
148:         savedAt: DateTime.now(),
149:       );
150:       await _knockoutRepo.save(pred);
151:       setState(() => _koPreds[rm.def.id] = pred);
152:       _recomputar();
153:       if (mounted) {
154:         ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
155:           content: Text('Palpite salvo!'),
156:           duration: Duration(seconds: 1),
157:           backgroundColor: Color(0xFF1A6B3C),
158:         ));
159:       }
160:     } catch (_) {
161:       if (mounted) {
162:         ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
163:           content: Text('Erro ao salvar palpite.'),
164:           backgroundColor: Colors.red,
165:         ));
166:       }
167:     } finally {
168:       if (mounted) setState(() => _saving[rm.def.id] = false);
169:     }
170:   }
171: 
172:   Future<void> _salvarTodos(List<ResolvedMatch> matches) async {
173:     final uid = FirebaseAuth.instance.currentUser!.uid;
174:     final salvando = matches.where((r) => r.canPredict).toList();
175:     if (salvando.isEmpty) return;
176:     setState(() => _savingAll = true);
177:     try {
178:       for (final rm in salvando) {
179:         final gols = _localPalpites[rm.def.id]!;
180:         final pred = KnockoutPrediction(
181:           slotId: rm.def.id,
182:           userId: uid,
183:           homeGoals: gols[0],
184:           awayGoals: gols[1],
185:           savedAt: DateTime.now(),
186:         );
187:         await _knockoutRepo.save(pred);
188:         _koPreds[rm.def.id] = pred;
189:       }
190:       _recomputar();
191:       if (mounted) {
192:         ScaffoldMessenger.of(context).showSnackBar(SnackBar(
193:           content: Text('${salvando.length} palpites salvos!'),
194:           backgroundColor: const Color(0xFF1A6B3C),
195:         ));
196:       }
197:     } catch (_) {
198:       if (mounted) {
199:         ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
200:           content: Text('Erro ao salvar palpites.'),
201:           backgroundColor: Colors.red,
202:         ));
203:       }
204:     } finally {
205:       if (mounted) setState(() => _savingAll = false);
206:     }
207:   }
208: 
209:   @override
210:   Widget build(BuildContext context) {
211:     if (_loading) return const Center(child: CircularProgressIndicator());
212:     if (_erro != null) return Center(child: Text(_erro!));
213: 
214:     return Column(
215:       children: [
216:         ColoredBox(
217:           color: const Color(0xFF1A6B3C),
218:           child: TabBar(
219:             controller: _tabController,
220:             labelColor: Colors.white,
221:             unselectedLabelColor: Colors.white60,
222:             indicatorColor: Colors.white,
223:             isScrollable: true,
224:             tabAlignment: TabAlignment.start,
225:             tabs: _tabPhases
226:                 .map((p) => Tab(text: BracketData.phaseLabels[p]))
227:                 .toList(),
228:           ),
229:         ),
230:         Expanded(
231:           child: TabBarView(
232:             controller: _tabController,
233:             children: _tabPhases.map((phase) {
234:               final matches = phase == 'final'
235:                   ? [
236:                       ..._resolved.where((r) => r.def.phase == 'final'),
237:                       ..._resolved.where((r) => r.def.phase == '3rd'),
238:                     ]
239:                   : _resolved.where((r) => r.def.phase == phase).toList();
240: 
241:               return _PhaseTab(
242:                 matches: matches,
243:                 teams: widget.teams,
244:                 cup: widget.cup,
245:                 localPalpites: _localPalpites,
246:                 saving: _saving,
247:                 savingAll: _savingAll,
248:                 onIncrement: _incrementar,
249:                 onDecrement: _decrementar,
250:                 onSave: _salvar,
251:                 onSaveAll: () => _salvarTodos(matches),
252:               );
253:             }).toList(),
254:           ),
255:         ),
256:       ],
257:     );
258:   }
259: }
