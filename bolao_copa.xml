174:   // Salva usuário novo no Firestore
175:   Future<void> _saveUserToFirestore({
176:     required String uid,
177:     required String name,
178:     required String email,
179:   }) async {
180:     await _db.collection('users').doc(uid).set({
181:       'name': name,
182:       'email': email,
183:       'is_admin': false,
184:       'total_points': 0,
185:       'created_at': FieldValue.serverTimestamp(),
186:     });
187:   }
188: }
