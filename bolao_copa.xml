  8: 
  9: class QuestionCard extends StatelessWidget {
 10:   final ExtraQuestion question;
 11:   final ExtraPrediction? prediction;
 12:   final List<Team> teams;
 13:   final List<Player> players;
 14:   final bool locked;
 15:   final Set<String> teamsExcluidos;
 16:   final Future<void> Function(String answer) onSave;
 17:   const QuestionCard({
 18:     super.key,
 19:     required this.question,
 20:     required this.prediction,
 21:     required this.teams,
 22:     required this.players,
 23:     required this.locked,
 24:     required this.teamsExcluidos,
 25:     required this.onSave,
 26:   });
 27:   Future<void> _abrirSelecao(BuildContext context) async {
 28:     if (locked) return;
 29:     if (question.type == ExtraQuestionType.team) {
 30:       final result = await showModalBottomSheet<String>(
 31:         context: context,
 32:         isScrollControlled: true,
 33:         shape: const RoundedRectangleBorder(
 34:           borderRadius: BorderRadius.vertical(top: Radius.circular(16)),
 35:         ),
 36:         builder: (_) => TeamSelectionSheet(
 37:           title: question.question,
 38:           teams: teams,
 39:           selectedId: prediction?.answer,
 40:           teamsExcluidos: teamsExcluidos,
 41:         ),
 42:       );
 43:       if (result != null) await onSave(result);
 44:     } else {
 45:       final result = await showModalBottomSheet<String>(
 46:         context: context,
 47:         isScrollControlled: true,
 48:         shape: const RoundedRectangleBorder(
 49:           borderRadius: BorderRadius.vertical(top: Radius.circular(16)),
 50:         ),
 51:         builder: (_) => PlayerSelectionSheet(
 52:           title: question.question,
 53:           teams: teams,
 54:           players: question.positionFilter != null
 55:               ? players
 56:                   .where((p) => p.position == question.positionFilter)
 57:                   .toList()
 58:               : players,
 59:           selectedPlayerId: prediction?.answer,
 60:         ),
 61:       );
 62:       if (result != null) await onSave(result);
 63:     }
 64:   }
 65: 
 66:   String _labelResposta() {
 67:     if (prediction == null || prediction!.answer.isEmpty) {
 68:       return 'Toque para responder';
 69:     }
 70:     if (question.type == ExtraQuestionType.team) {
 71:       return teams
 72:           .firstWhere((t) => t.id == prediction!.answer,
 73:               orElse: () =>
 74:                   const Team(id: '', name: 'Desconhecido', flagAsset: ''))
 75:           .name;
 76:     }
 77:     final player = players.firstWhere(
 78:       (p) => p.id == prediction!.answer,
 79:       orElse: () =>
 80:           const Player(id: '', name: 'Desconhecido', teamId: '', position: ''),
 81:     );
 82:     final team = teams.firstWhere(
 83:       (t) => t.id == player.teamId,
 84:       orElse: () => const Team(id: '', name: '', flagAsset: ''),
 85:     );
 86:     return team.name.isNotEmpty ? '${player.name} (${team.name})' : player.name;
 87:   }
 88: 
 89:   Widget _leading() {
 90:     if (prediction == null || prediction!.answer.isEmpty) {
 91:       return const Icon(Icons.help_outline, size: 32, color: Colors.grey);
 92:     }
 93:     String? flagAsset;
 94:     if (question.type == ExtraQuestionType.team) {
 95:       flagAsset = teams
 96:           .firstWhere((t) => t.id == prediction!.answer,
 97:               orElse: () => const Team(id: '', name: '', flagAsset: ''))
 98:           .flagAsset;
 99:     } else {
100:       final player = players.firstWhere(
101:         (p) => p.id == prediction!.answer,
102:         orElse: () => const Player(id: '', name: '', teamId: '', position: ''),
103:       );
104:       flagAsset = teams
105:           .firstWhere((t) => t.id == player.teamId,
106:               orElse: () => const Team(id: '', name: '', flagAsset: ''))
107:           .flagAsset;
108:     }
109:     if (flagAsset.isEmpty) {
110:       return Icon(
111:         question.type == ExtraQuestionType.team
112:             ? Icons.flag_outlined
113:             : Icons.person_outline,
114:         size: 32,
115:       );
116:     }
117:     return ClipRRect(
118:       borderRadius: BorderRadius.circular(4),
119:       child: Image.asset(flagAsset,
120:           width: 48,
121:           height: 32,
122:           fit: BoxFit.cover,
123:           errorBuilder: (_, __, ___) =>
124:               const Icon(Icons.flag_outlined, size: 32)),
125:     );
126:   }
127: 
128:   @override
129:   Widget build(BuildContext context) {
130:     final respondido = prediction != null && prediction!.answer.isNotEmpty;
131:     return Card(
132:       margin: const EdgeInsets.symmetric(vertical: 6),
133:       child: ListTile(
134:         leading: _leading(),
135:         title: Text(question.question,
136:             style: const TextStyle(fontWeight: FontWeight.bold)),
137:         subtitle: Text(
138:           _labelResposta(),
139:           style: TextStyle(
140:               color: respondido ? const Color(0xFF1A6B3C) : Colors.grey),
141:         ),
142:         trailing: locked
143:             ? const Icon(Icons.lock_outline, color: Colors.orange)
144:             : const Icon(Icons.chevron_right),
145:         onTap: locked ? null : () => _abrirSelecao(context),
146:       ),
147:     );
148:   }
149: }
</file>

