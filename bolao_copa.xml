  7: class ManageMatchesScreen extends StatefulWidget {
  8:   const ManageMatchesScreen({super.key});
  9:   @override
 10:   State<ManageMatchesScreen> createState() => _ManageMatchesScreenState();
 11: }
 12: class _ManageMatchesScreenState extends State<ManageMatchesScreen>
 13:     with SingleTickerProviderStateMixin {
 14:   final _matchRepo = MatchRepository();
 15:   final _firestoreService = FirestoreService();
 16:   late TabController _tabController;
 17:   List<Match> _groupMatches = [];
 18:   List<Match> _knockoutMatches = [];
 19:   Map<String, Team> _teams = {};
 20:   bool _loading = true;
 21:   String? _erro;
 22:   @override
 23:   void initState() {
 24:     super.initState();
 25:     _tabController = TabController(length: 2, vsync: this);
 26:     _carregar();
 27:   }
 28:   @override
 29:   void dispose() {
 30:     _tabController.dispose();
 31:     super.dispose();
 32:   }
 33:   Future<void> _carregar() async {
 34:     try {
 35:       final cup = await _firestoreService.fetchActiveCup();
 36:       if (cup == null) {
 37:         setState(() {
 38:           _erro = 'Nenhum bolão ativo encontrado.';
 39:           _loading = false;
 40:         });
 41:         return;
 42:       }
 43:       final results = await Future.wait([
 44:         _matchRepo.fetchGroupMatches(cup.id),
 45:         _matchRepo.fetchKnockoutMatches(cup.id),
 46:         _matchRepo.fetchTeams(cup.id),
 47:       ]);
 48:       setState(() {
 49:         _groupMatches = results[0] as List<Match>;
 50:         _knockoutMatches = results[1] as List<Match>;
 51:         _teams = results[2] as Map<String, Team>;
 52:         _loading = false;
 53:       });
 54:     } catch (e) {
 55:       setState(() {
 56:         _erro = 'Erro ao carregar jogos.';
 57:         _loading = false;
 58:       });
 59:     }
 60:   }
 61:   @override
 62:   Widget build(BuildContext context) {
 63:     return Scaffold(
 64:       appBar: AppBar(
 65:         title: const Text('Gerenciar Jogos'),
 66:         backgroundColor: const Color(0xFF1A6B3C),
 67:         foregroundColor: Colors.white,
 68:         bottom: TabBar(
 69:           controller: _tabController,
 70:           labelColor: Colors.white,
 71:           unselectedLabelColor: Colors.white60,
 72:           indicatorColor: Colors.white,
 73:           tabs: const [
 74:             Tab(text: 'Fase de Grupos'),
 75:             Tab(text: 'Mata-Mata'),
 76:           ],
 77:         ),
 78:       ),
 79:       body: _loading
 80:           ? const Center(child: CircularProgressIndicator())
 81:           : _erro != null
 82:               ? Center(child: Text(_erro!))
 83:               : TabBarView(
 84:                   controller: _tabController,
 85:                   children: [
 86:                     _buildList(_groupMatches),
 87:                     _buildList(_knockoutMatches),
 88:                   ],
 89:                 ),
 90:     );
 91:   }
 92:   Widget _buildList(List<Match> matches) {
 93:     if (matches.isEmpty) {
 94:       return const Center(child: Text('Nenhum jogo cadastrado.'));
 95:     }
 96:     return ListView.builder(
 97:       padding: const EdgeInsets.symmetric(vertical: 8),
 98:       itemCount: matches.length,
 99:       itemBuilder: (context, index) {
100:         final match = matches[index];
101:         final home = _teams[match.homeTeamId];
102:         final away = _teams[match.awayTeamId];
103:         final dateStr =
104:             DateFormat('dd/MM/yyyy · HH:mm').format(match.matchTime);
105:         return Card(
106:           margin:
107:               const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
108:           child: ListTile(
109:             title: Text(
110:               '${home?.name ?? match.homeTeamId} × ${away?.name ?? match.awayTeamId}',
111:               style: const TextStyle(fontWeight: FontWeight.bold),
112:             ),
113:             subtitle: Text(dateStr),
114:             trailing: match.finished
115:                 ? Text(
116:                     '${match.officialHomeGoals} × ${match.officialAwayGoals}',
117:                     style: const TextStyle(
118:                         fontWeight: FontWeight.bold,
119:                         color: Color(0xFF1A6B3C)),
120:                   )
121:                 : const Text('Pendente',
122:                     style: TextStyle(color: Colors.grey)),
123:           ),
124:         );
125:       },
126:     );
127:   }
128: }
</file>

