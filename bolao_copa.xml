<file path="firestore.rules">
 1: rules_version = '2';
 2: service cloud.firestore {
 3:   match /databases/{database}/documents {
 4: 
 5:     // ── Funções auxiliares ────────────────────────────────────────────────
 6:     function isAuth() {
 7:       return request.auth != null;
 8:     }
 9:     function isMember(groupId) {
10:       return isAuth() &&
11:         exists(/databases/$(database)/documents/bolao_groups/$(groupId)/members/$(request.auth.uid));
12:     }
13:     function isGroupAdmin(groupId) {
14:       return isAuth() &&
15:         get(/databases/$(database)/documents/bolao_groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
16:     }
17:     function isAdmin() {
18:       return isAuth() &&
19:         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true;
20:     }
21:     // ── Usuários ──────────────────────────────────────────────────────────
22:     match /users/{userId} {
23:       allow read: if isAuth();
24:       allow write: if isAuth() && request.auth.uid == userId;
25: 
26:       match /knockout_predictions/{slotId} {
27:         allow read: if isAuth();
28:         allow write: if isAuth() && request.auth.uid == userId;
29:       }
30:     }
31: 
32:     // ── Copa e subcoleções: leitura para autenticados ─────────────────────
33:     match /cups/{cupId} {
34:       allow read: if isAuth();
35:       match /{document=**} {
36:         allow read: if isAuth();
37:         allow write: if isAuth();
38:       }
39:     }
40: 
41:     match /{path=**}/matches/{matchId} {
42:       allow read: if isAuth();
43:     }
44:     match /{path=**}/teams/{teamId} {
45:       allow read: if isAuth();
46:     }
47:     match /{path=**}/players/{playerId} {
48:       allow read: if isAuth();
49:     }
50:     match /{path=**}/extra_questions/{questionId} {
51:       allow read: if isAuth();
52:     }
53: 
54:     // ── Grupos do bolão ───────────────────────────────────────────────────
55:     match /bolao_groups/{groupId} {
56:       allow get: if isAuth();
57:       allow list: if isAuth();
58:       // Criação: qualquer autenticado
59:       allow create: if isAuth();
60:       // Atualização e deleção: apenas admin do grupo
61:       allow update, delete: if isGroupAdmin(groupId);
62: 
63:       // Membros
64:       match /members/{userId} {
65:   allow read: if isMember(groupId) || (isAuth() && request.auth.uid == userId);
66:   allow create, update: if (isAuth() && request.auth.uid == userId) || isGroupAdmin(groupId);
67:         // Admin pode remover membros
68:         allow delete: if isGroupAdmin(groupId) || request.auth.uid == userId;
69: 
70:         // Palpites de jogo — isolados por grupo
71:         match /predictions/{matchId} {
72:           allow read: if isMember(groupId);
73:           allow write: if isAuth() && request.auth.uid == userId;
74:         }
75: 
76:         // Palpites extras — isolados por grupo
77:         match /extra_predictions/{questionId} {
78:           allow read: if isMember(groupId);
79:           allow write: if isAuth() && request.auth.uid == userId;
80:         }
81:       }
82:     }
83:   }
84: }
</file>

