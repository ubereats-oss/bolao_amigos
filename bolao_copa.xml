 67:   bool _isX(Data? cell) {
 68:     final v = cell?.value;
 69:     if (v is TextCellValue) return v.value.toString().trim().toLowerCase() == 'x';
 70:     return false;
 71:   }
 72: 
 73:   String? _cellStr(Data? cell) {
 74:     final v = cell?.value;
 75:     if (v is TextCellValue) {
 76:       final s = v.value.toString().trim();
 77:       return s.isEmpty ? null : s;
 78:     }
 79:     return null;
 80:   }
 81: 
 82:   int? _cellInt(Data? cell) {
 83:     final v = cell?.value;
 84:     if (v is IntCellValue) return v.value;
 85:     if (v is DoubleCellValue) return v.value.round();
 86:     if (v is TextCellValue) return int.tryParse(v.value.toString().trim());
 87:     return null;
 88:   }
