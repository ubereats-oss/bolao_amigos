 90:   Data? _cell(List<Data?> row, int idx) => idx < row.length ? row[idx] : null;
 91: 
 92:   void _processarBloco(
 93:     List<Data?> row, int xi, int ci, int hi, int vi, int ai,
 94:     Map<String, Match> lk, List<ResultadoImportado> out,
 95:   ) {
 96:     if (!_isX(_cell(row, xi))) return;
 97:     final nc = _cellStr(_cell(row, ci));
 98:     final nv = _cellStr(_cell(row, vi));
 99:     final hg = _cellInt(_cell(row, hi));
100:     final ag = _cellInt(_cell(row, ai));
101:     if (nc == null || nv == null || hg == null || ag == null) return;
102:     final hid = teamNameToId[nc];
103:     final aid = teamNameToId[nv];
104:     out.add(ResultadoImportado(
105:       match: hid != null && aid != null ? lk['$hid|$aid'] : null,
106:       homeGoals: hg, awayGoals: ag, nomeCasa: nc, nomeVisitante: nv,
107:     ));
108:   }
