 12: class AuthService {
 13:   final FirebaseAuth _auth = FirebaseAuth.instance;
 14:   final GoogleSignIn _googleSignIn = GoogleSignIn();
 15:   final FirebaseFirestore _db = FirebaseFirestore.instance;
 16:   // Usuário autenticado atual
 17:   User? get currentUser => _auth.currentUser;
 18:   // Stream de mudanças de autenticação
 19:   Stream<User?> get authStateChanges => _auth.authStateChanges();
 20:   // Login com e-mail e senha
 21:   Future<UserCredential> signInWithEmail(String email, String password) async {
 22:     return await _auth.signInWithEmailAndPassword(
 23:       email: email.trim(),
 24:       password: password,
 25:     );
 26:   }
 27: 
 28:   // Registro com e-mail e senha
 29:   Future<UserCredential> registerWithEmail({
 30:     required String name,
 31:     required String email,
 32:     required String password,
 33:   }) async {
 34:     final credential = await _auth.createUserWithEmailAndPassword(
 35:       email: email.trim(),
 36:       password: password,
 37:     );
 38:     await credential.user?.updateDisplayName(name);
 39:     await _saveUserToFirestore(
 40:       uid: credential.user!.uid,
 41:       name: name,
 42:       email: email.trim(),
 43:     );
 44:     return credential;
 45:   }
 46: 
 47:   // Login com Google
 48:   Future<UserCredential?> signInWithGoogle() async {
 49:     final googleUser = await _googleSignIn.signIn();
 50:     if (googleUser == null) return null;
 51:     final googleAuth = await googleUser.authentication;
 52:     final credential = GoogleAuthProvider.credential(
 53:       accessToken: googleAuth.accessToken,
 54:       idToken: googleAuth.idToken,
 55:     );
 56:     final userCredential = await _auth.signInWithCredential(credential);
 57:     // Cria o perfil no Firestore apenas se for o primeiro login
 58:     final doc =
 59:         await _db.collection('users').doc(userCredential.user!.uid).get();
 60:     if (!doc.exists) {
 61:       await _saveUserToFirestore(
 62:         uid: userCredential.user!.uid,
 63:         name: googleUser.displayName ?? 'Usuário',
 64:         email: googleUser.email,
 65:       );
 66:     }
 67:     return userCredential;
 68:   }
 69: 
 70:   String _generateNonce([int length = 32]) {
 71:     const charset =
 72:         '0123456789ABCDEFGHIJKLMNOPQRSTUVXYZabcdefghijklmnopqrstuvwxyz-._';
 73:     final random = Random.secure();
 74:     return List.generate(
 75:         length, (_) => charset[random.nextInt(charset.length)]).join();
 76:   }
 77: 
 78:   String _sha256ofString(String input) {
 79:     final bytes = utf8.encode(input);
 80:     final digest = sha256.convert(bytes);
 81:     return digest.toString();
 82:   }
 83: 
 84:   Future<UserCredential> signInWithApple() async {
 85:     final rawNonce = _generateNonce();
 86:     final nonce = _sha256ofString(rawNonce);
 87: 
 88:     final appleCredential = await SignInWithApple.getAppleIDCredential(
 89:       scopes: [
 90:         AppleIDAuthorizationScopes.email,
 91:         AppleIDAuthorizationScopes.fullName,
 92:       ],
 93:       nonce: nonce,
 94:       webAuthenticationOptions: !kIsWeb && Platform.isIOS
 95:           ? null
 96:           : WebAuthenticationOptions(
 97:               clientId: 'com.salles.bolaocopadomundo.signin',
 98:               redirectUri: Uri.parse(
 99:                 'https://bolao-copa-do-mundo-salles.firebaseapp.com/__/auth/handler',
100:               ),
101:             ),
102:     );
103: 
104:     final idToken = appleCredential.identityToken;
105:     if (idToken == null || idToken.isEmpty) {
106:       throw Exception(
107:         'Apple não retornou um token de identidade. '
108:         'Verifique suas configurações de conta Apple ID e tente novamente.',
109:       );
110:     }
111: 
112:     final oauthCredential = OAuthProvider('apple.com').credential(
113:       idToken: idToken,
114:       rawNonce: rawNonce,
115:       accessToken: appleCredential.authorizationCode,
116:     );
117: 
118:     final userCredential = await _auth.signInWithCredential(oauthCredential);
119: 
120:     final isNew = userCredential.additionalUserInfo?.isNewUser ?? false;
121:     if (isNew) {
122:       final given = appleCredential.givenName ?? '';
123:       final family = appleCredential.familyName ?? '';
124:       final name = [given, family].where((s) => s.isNotEmpty).join(' ').trim();
125:       await _saveUserToFirestore(
126:         uid: userCredential.user!.uid,
127:         name: name.isEmpty ? 'Usuário' : name,
128:         email: appleCredential.email ?? userCredential.user!.email ?? '',
129:       );
130:     }
131: 
132:     return userCredential;
133:   }
