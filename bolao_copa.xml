 73:   Future<void> _salvarResultado(Match match, int home, int away) async {
 74:     if (_cupId == null) return;
 75:     final collection = match.groupId != null
 76:         ? _db
 77:             .collection('cups')
 78:             .doc(_cupId)
 79:             .collection('groups')
 80:             .doc(match.groupId)
 81:             .collection('matches')
 82:         : _db.collection('cups').doc(_cupId).collection('knockout_matches');
 83:     await collection.doc(match.id).update({
 84:       'official_home_goals': home,
 85:       'official_away_goals': away,
 86:       'finished': true,
 87:     });
 88:     MatchRepository.clearCache();
 89:     await _carregar(forceRefresh: true);
 90:     await _recalcularTodos();
