133:   Future<void> _salvarTodos() async {
134:     if (_cupId == null) return;
135:     setState(() => _recalculando = true);
136:     try {
137:       final validos = _resultados.where((r) => r.encontrado).toList();
138:       for (final r in validos) {
139:         final m = r.match!;
140:         final col = m.groupId != null
141:             ? _db.collection('cups').doc(_cupId).collection('groups')
142:                 .doc(m.groupId).collection('matches')
143:             : _db.collection('cups').doc(_cupId).collection('knockout_matches');
144:         await col.doc(m.id).set({
145:           'official_home_goals': r.homeGoals,
146:           'official_away_goals': r.awayGoals,
147:           'finished': true,
148:         }, SetOptions(merge: true));
149:       }
150:       MatchRepository.clearCache();
151:       if (widget.groupId.isNotEmpty) {
152:         await _recalcularTodos(validos.length);
153:       } else {
154:         if (mounted) setState(() => _recalculando = false);
155:         if (mounted) _mostrarSucesso(validos.length, comRecalculo: false);
