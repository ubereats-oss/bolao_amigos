 1: import 'package:cloud_firestore/cloud_firestore.dart';
 2: import '../data/models/cup.dart';
 3: class FirestoreService {
 4:   final FirebaseFirestore _db = FirebaseFirestore.instance;
 5:   // Cache em memória — evita leituras repetidas ao Firestore
 6:   static Cup? _cachedCup;
 7:   Future<Cup?> fetchActiveCup({bool forceRefresh = false}) async {
 8:     if (!forceRefresh && _cachedCup != null) return _cachedCup;
 9:     final query = await _db
10:         .collection('cups')
11:         .where('active', isEqualTo: true)
12:         .limit(1)
13:         .get();
14:     if (query.docs.isEmpty) return null;
15:     final doc = query.docs.first;
16:     _cachedCup = Cup.fromFirestore(doc.id, doc.data());
17:     return _cachedCup;
18:   }
19:   static void clearCache() {
20:     _cachedCup = null;
21:   }
22: }
</file>

<file path="lib/services/scoring_service.dart">
  1: import 'package:cloud_firestore/cloud_firestore.dart';
  2: import '../data/models/match.dart';
  3: import '../data/models/prediction.dart';
  4: import '../data/models/extra_prediction.dart';
  5: import '../data/models/extra_question.dart';
  6: import '../data/repositories/group_repository.dart';
  7: import '../data/repositories/match_repository.dart';
  8: 
  9: class ScoringService {
 10:   final _matchRepo = MatchRepository();
 11:   final _groupRepo = GroupRepository();
 12:   final _db = FirebaseFirestore.instance;
 13: 
 14:   Future<int> calcularPontos({
 15:     required String groupId,
 16:     required String userId,
 17:     required String cupId,
 18:   }) async {
 19:     int total = 0;
 20: 
 21:     final matches = await _matchRepo.fetchGroupMatches(cupId);
 22:     final finished = matches.where((m) => m.finished).toList();
 23: 
 24:     if (finished.isNotEmpty) {
 25:       final predictions = await _groupRepo.fetchAllPredictions(groupId, userId);
 26:       for (final match in finished) {
 27:         final pred = predictions[match.id];
 28:         if (pred != null) total += _calcMatchPoints(match, pred);
 29:       }
 30:     }
 31: 
 32:     final questionsSnap = await _db
 33:         .collection('cups')
 34:         .doc(cupId)
 35:         .collection('extra_questions')
 36:         .orderBy('order')
 37:         .get();
 38: 
 39:     final questions = questionsSnap.docs
 40:         .map((d) => ExtraQuestion.fromFirestore(d.id, d.data()))
 41:         .where((q) => q.correctAnswer != null && q.correctAnswer!.isNotEmpty)
 42:         .toList();
 43: 
 44:     if (questions.isNotEmpty) {
 45:       final extras = await _groupRepo.fetchAllExtraPredictions(groupId, userId);
 46:       for (final q in questions) {
 47:         final pred = extras[q.id];
 48:         if (pred != null) total += _calcExtraPoints(q, pred);
 49:       }
 50:     }
 51: 
 52:     return total;
 53:   }
 54: 
 55:   int _calcMatchPoints(Match match, Prediction pred) {
 56:     final oh = match.officialHomeGoals!;
 57:     final oa = match.officialAwayGoals!;
 58:     final ph = pred.homeGoals;
 59:     final pa = pred.awayGoals;
 60: 
 61:     if (oh == ph && oa == pa) return 13;
 62: 
 63:     final officialSign = oh.compareTo(oa);
 64:     final predSign = ph.compareTo(pa);
 65:     if (officialSign == predSign) return 6;
 66: 
 67:     if (oh == ph || oa == pa) return 2;
 68: 
 69:     return 0;
 70:   }
 71: 
 72:   int _calcExtraPoints(ExtraQuestion question, ExtraPrediction pred) {
 73:     final correct = question.correctAnswer!;
 74:     final answer = pred.answer;
 75:     final order = question.order;
 76: 
 77:     if (order == 4 || order == 5 || order == 6) {
 78:       return _calcListPoints(order, answer, correct);
 79:     }
 80: 
 81:     if (answer.trim().toLowerCase() == correct.trim().toLowerCase()) {
 82:       return _pointsForOrder(order);
 83:     }
 84:     return 0;
 85:   }
 86: 
 87:   int _calcListPoints(int order, String answer, String correct) {
 88:     final answerSet =
 89:         answer.split(',').map((s) => s.trim().toLowerCase()).toSet();
 90:     final correctSet =
 91:         correct.split(',').map((s) => s.trim().toLowerCase()).toSet();
 92:     final matches = answerSet.intersection(correctSet).length;
 93:     return matches * _pointsForOrder(order);
 94:   }
 95: 
 96:   int _pointsForOrder(int order) {
 97:     const table = {
 98:       1: 7,
