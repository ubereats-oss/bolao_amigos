<file path="lib/features/matches/bracket_engine.dart">
  1: import '../../core/constants/bracket_data.dart';
  2: import '../../data/models/group_standing.dart';
  3: import '../../data/models/match.dart';
  4: import '../../data/models/knockout_prediction.dart';
  5: 
  6: /// Resultado resolvido de um confronto do mata-mata
  7: class ResolvedMatch {
  8:   final BracketMatchDef def;
  9:   final String? homeTeamId;
 10:   final String? awayTeamId;
 11:   final bool canPredict;
 12:   // Labels legíveis do slot, ex: '1º A', '2º B', 'Melhor 3º (A/B/C/D/F)'
 13:   final String homeSlotLabel;
 14:   final String awaySlotLabel;
 15: 
 16:   const ResolvedMatch({
 17:     required this.def,
 18:     this.homeTeamId,
 19:     this.awayTeamId,
 20:     required this.canPredict,
 21:     required this.homeSlotLabel,
 22:     required this.awaySlotLabel,
 23:   });
 24: }
 25: 
 26: class BracketEngine {
 27:   final List<Match> groupMatches;
 28:   // null = sem palpite (jogo ignorado no cálculo de classificação)
 29:   final Map<String, List<int>?> groupPredictions;
 30:   final Map<String, KnockoutPrediction> knockoutPredictions;
 31:   final Map<String, List<String>> groupTeams;
 32: 
 33:   BracketEngine({
 34:     required this.groupMatches,
 35:     required this.groupPredictions,
 36:     required this.knockoutPredictions,
 37:     required this.groupTeams,
 38:   });
 39: 
 40:   // ─── Monta groupTeams de forma robusta ────────────────────────────────────
 41:   Map<String, List<String>> _effectiveGroupTeams() {
 42:     if (groupTeams.isNotEmpty) {
 43:       return groupTeams;
 44:     }
 45:     final Map<String, List<String>> result = {};
 46:     for (final m in groupMatches) {
 47:       final gid = m.groupId;
 48:       if (gid == null || gid.isEmpty) continue;
 49:       result.putIfAbsent(gid, () => []);
 50:       if (!result[gid]!.contains(m.homeTeamId)) result[gid]!.add(m.homeTeamId);
 51:       if (!result[gid]!.contains(m.awayTeamId)) result[gid]!.add(m.awayTeamId);
 52:     }
 53:     return result;
 54:   }
 55: 
 56:   // ─── Cálculo das tabelas de grupo ─────────────────────────────────────────
 57: 
 58:   Map<String, GroupStanding> computeStandings() {
 59:     final effective = _effectiveGroupTeams();
 60:     final Map<String, Map<String, TeamStanding>> raw = {};
 61:     for (final entry in effective.entries) {
 62:       raw[entry.key] = {
 63:         for (final t in entry.value) t: TeamStanding(teamId: t)
 64:       };
 65:     }
 66: 
 67:     for (final match in groupMatches) {
 68:       final gid = match.groupId;
 69:       if (gid == null || gid.isEmpty) continue;
 70: 
 71:       final palpite = groupPredictions[match.id];
 72:       if (palpite == null) continue; // sem palpite: ignora no cálculo
 73: 
 74:       final hGoals = palpite[0];
 75:       final aGoals = palpite[1];
 76: 
 77:       final home = raw[gid]?[match.homeTeamId];
 78:       final away = raw[gid]?[match.awayTeamId];
 79:       if (home == null || away == null) continue;
 80: 
 81:       home.goalsFor += hGoals;
 82:       home.goalsAgainst += aGoals;
 83:       away.goalsFor += aGoals;
 84:       away.goalsAgainst += hGoals;
 85: 
 86:       if (hGoals > aGoals) {
 87:         home.points += 3;
 88:       } else if (hGoals == aGoals) {
 89:         home.points += 1;
 90:         away.points += 1;
 91:       } else {
 92:         away.points += 3;
 93:       }
 94:     }
 95: 
 96:     final result = <String, GroupStanding>{};
 97:     for (final entry in raw.entries) {
 98:       final sorted = entry.value.values.toList()
 99:         ..sort((a, b) {
100:           final pts = b.points.compareTo(a.points);
101:           if (pts != 0) return pts;
102:           final diff = b.goalDiff.compareTo(a.goalDiff);
103:           if (diff != 0) return diff;
104:           final gf = b.goalsFor.compareTo(a.goalsFor);
105:           if (gf != 0) return gf;
106:           return a.teamId.compareTo(b.teamId);
107:         });
108:       result[entry.key] = GroupStanding(groupId: entry.key, standings: sorted);
109:     }
110:     return result;
111:   }
112: 
113:   // ─── Melhores 3ºs colocados ────────────────────────────────────────────────
114: 
115:   List<MapEntry<String, TeamStanding>> computeBestThirds(
116:       Map<String, GroupStanding> standings) {
117:     final thirds = <MapEntry<String, TeamStanding>>[];
118:     for (final gs in standings.values) {
119:       if (gs.standings.length >= 3) {
120:         thirds.add(MapEntry(gs.groupId, gs.standings[2]));
121:       }
122:     }
123:     thirds.sort((a, b) {
124:       final pts = b.value.points.compareTo(a.value.points);
125:       if (pts != 0) return pts;
126:       final diff = b.value.goalDiff.compareTo(a.value.goalDiff);
127:       if (diff != 0) return diff;
128:       final gf = b.value.goalsFor.compareTo(a.value.goalsFor);
129:       if (gf != 0) return gf;
130:       return a.key.compareTo(b.key);
131:     });
132:     return thirds.take(8).toList();
133:   }
134: 
135:   // ─── Atribuição dos melhores 3ºs via backtracking ─────────────────────────
136:   //
137:   // O algoritmo greedy sequencial falha quando os candidatos se sobrepõem
138:   // (ex: grupo I aparece em 6 dos 8 slots). O backtracking garante encontrar
139:   // a atribuição válida para qualquer combinação de 8 grupos qualificados.
140:   //
141:   // Retorna mapa de "${def.id}_h" ou "${def.id}_a" → teamId.
142: 
143:   Map<String, String?> _assignBestThirds(
144:       List<MapEntry<String, TeamStanding>> bestThirds) {
145:     final defIds = <String>[];
146:     final isHomeSlot = <bool>[];
147:     final groupCandidates = <List<String>>[];
148: 
149:     for (final def in BracketData.r32) {
150:       if (def.home.isThird) {
151:         defIds.add(def.id);
152:         isHomeSlot.add(true);
153:         groupCandidates.add(def.home.thirdGroups);
154:       }
155:       if (def.away.isThird) {
156:         defIds.add(def.id);
157:         isHomeSlot.add(false);
158:         groupCandidates.add(def.away.thirdGroups);
159:       }
160:     }
161: 
162:     final assignment = <int, int>{}; // slotIndex -> bestThirds index
163:     final usedIdx = <int>{};
164: 
165:     bool backtrack(int si) {
166:       if (si >= defIds.length) return true;
167:       final groups = groupCandidates[si];
168: 
169:       for (int ti = 0; ti < bestThirds.length; ti++) {
170:         if (usedIdx.contains(ti)) continue;
171:         if (!groups.contains(bestThirds[ti].key)) continue;
172: 
173:         assignment[si] = ti;
174:         usedIdx.add(ti);
175:         if (backtrack(si + 1)) return true;
176:         assignment.remove(si);
177:         usedIdx.remove(ti);
178:       }
179:       return false;
180:     }
181: 
182:     backtrack(0);
183: 
184:     final result = <String, String?>{};
185:     for (int si = 0; si < defIds.length; si++) {
186:       final key = '${defIds[si]}_${isHomeSlot[si] ? 'h' : 'a'}';
187:       final ti = assignment[si];
188:       result[key] = ti != null ? bestThirds[ti].value.teamId : null;
189:     }
190:     return result;
191:   }
192: 
193:   // ─── Resolução de slots (exceto Melhor 3º, tratado por _assignBestThirds) ──
194: 
195:   String? resolveSlot(
196:     String code,
197:     Map<String, GroupStanding> standings,
198:     Map<String, String> winners,
199:   ) {
200:     if (code.startsWith('W') || code.startsWith('L')) {
201:       final isWinner = code.startsWith('W');
202:       final matchId = code.substring(1);
203:       return isWinner ? winners['W$matchId'] : winners['L$matchId'];
204:     }
205:     if (code.startsWith('1') || code.startsWith('2')) {
206:       final pos = int.parse(code[0]) - 1;
207:       final groupId = code.substring(1);
208:       final gs = standings[groupId];
209:       if (gs == null || gs.standings.length <= pos) return null;
210:       return gs.standings[pos].teamId;
211:     }
212:     return null;
213:   }
214: 
215:   // ─── Label legível do slot ─────────────────────────────────────────────────
216: 
217:   String _slotLabel(String code) {
218:     if (code.startsWith('W')) return 'Vencedor ${code.substring(1)}';
219:     if (code.startsWith('L')) return 'Perdedor ${code.substring(1)}';
220:     if (code.startsWith('1')) return '1º ${code.substring(1)}';
221:     if (code.startsWith('2')) return '2º ${code.substring(1)}';
222:     if (code.startsWith('3')) {
223:       final grupos = code.substring(1).split('').join('/');
224:       return 'Melhor 3º ($grupos)';
225:     }
226:     return code;
227:   }
228: 
229:   // ─── Resolução completa do chaveamento ─────────────────────────────────────
230: 
231:   List<ResolvedMatch> resolveAll() {
232:     final standings = computeStandings();
233:     final bestThirds = computeBestThirds(standings);
234:     final thirdsAssignment = _assignBestThirds(bestThirds);
235: 
236:     final Map<String, String> resolved = {};
237:     final phaseOrder = ['r32', 'r16', 'qf', 'sf', 'final', '3rd'];
238:     final result = <ResolvedMatch>[];
239:     final phasePredicted = <String, bool>{};
240:     phasePredicted['group'] = true;
241: 
242:     for (final phase in phaseOrder) {
243:       final matches = BracketData.matchesForPhase(phase);
244:       final prevPhase = _previousPhase(phase);
245:       final prevDone = phasePredicted[prevPhase] ?? false;
246:       bool allThisPhasePredicted = true;
247: 
248:       for (final def in matches) {
249:         final homeId = def.home.isThird
250:             ? thirdsAssignment['${def.id}_h']
251:             : resolveSlot(def.home.code, standings, resolved);
252: 
253:         final awayId = def.away.isThird
254:             ? thirdsAssignment['${def.id}_a']
255:             : resolveSlot(def.away.code, standings, resolved);
256: 
257:         final canPredict = prevDone && homeId != null && awayId != null;
258: 
259:         result.add(ResolvedMatch(
260:           def: def,
261:           homeTeamId: homeId,
262:           awayTeamId: awayId,
263:           canPredict: canPredict,
264:           homeSlotLabel: _slotLabel(def.home.code),
265:           awaySlotLabel: _slotLabel(def.away.code),
266:         ));
267: 
268:         final pred = knockoutPredictions[def.id];
269:         if (pred != null && homeId != null && awayId != null) {
270:           String winner;
271:           String loser;
272:           if (pred.homeGoals > pred.awayGoals) {
273:             winner = homeId;
274:             loser = awayId;
275:           } else if (pred.awayGoals > pred.homeGoals) {
276:             winner = awayId;
277:             loser = homeId;
278:           } else {
279:             winner = homeId;
280:             loser = awayId;
281:           }
282:           resolved['W${def.id}'] = winner;
283:           resolved['L${def.id}'] = loser;
284:         } else {
285:           allThisPhasePredicted = false;
286:         }
287:       }
288: 
289:       phasePredicted[phase] = allThisPhasePredicted;
290:     }
291: 
292:     return result;
293:   }
294: 
295:   String _previousPhase(String phase) {
296:     switch (phase) {
297:       case 'r32':
298:         return 'group';
299:       case 'r16':
300:         return 'r32';
301:       case 'qf':
302:         return 'r16';
303:       case 'sf':
304:         return 'qf';
305:       case 'final':
306:         return 'sf';
307:       case '3rd':
308:         return 'sf';
309:       default:
310:         return 'group';
311:     }
312:   }
313: }
</file>

