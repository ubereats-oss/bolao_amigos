 93:   Future<void> _recalcularTodos() async {
 94:     if (_cupId == null) return;
 95:     setState(() => _recalculando = true);
 96:     try {
 97:       final members = await _groupRepo.fetchMembers(widget.groupId);
 98:       await Future.wait(
 99:         members.map((m) async {
100:           final pts = await _scoringService.calcularPontos(
101:             groupId: widget.groupId,
102:             userId: m.userId,
103:             cupId: _cupId!,
104:           );
105:           await _groupRepo.updateMemberPoints(widget.groupId, m.userId, pts);
106:         }),
107:       );
