rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isMember(groupId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/bolao_groups/$(groupId)/members/$(request.auth.uid));
    }
    function isGroupAdmin(groupId) {
      return isAuth() &&
        get(/databases/$(database)/documents/bolao_groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true;
    }
    // ── Usuários ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;

      match /knockout_predictions/{slotId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Copa e subcoleções: leitura para autenticados ─────────────────────
    match /cups/{cupId} {
      allow read: if isAuth();
      match /{document=**} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    match /{path=**}/matches/{matchId} {
      allow read: if isAuth();
    }
    match /{path=**}/teams/{teamId} {
      allow read: if isAuth();
    }
    match /{path=**}/players/{playerId} {
      allow read: if isAuth();
    }
    match /{path=**}/extra_questions/{questionId} {
      allow read: if isAuth();
    }

    // ── Grupos do bolão ───────────────────────────────────────────────────
    match /bolao_groups/{groupId} {
      allow get: if isAuth();
      allow list: if isAuth();
      // Criação: qualquer autenticado
      allow create: if isAuth();
      // Atualização e deleção: apenas admin do grupo
      allow update, delete: if isGroupAdmin(groupId);

      // Membros
      match /members/{userId} {
  allow read: if isMember(groupId) || (isAuth() && request.auth.uid == userId);
  allow create, update: if (isAuth() && request.auth.uid == userId) || isGroupAdmin(groupId);
        // Admin pode remover membros
        allow delete: if isGroupAdmin(groupId) || request.auth.uid == userId;

        // Palpites de jogo — isolados por grupo
        match /predictions/{matchId} {
          allow read: if isMember(groupId);
          allow write: if isAuth() && request.auth.uid == userId;
        }

        // Palpites extras — isolados por grupo
        match /extra_predictions/{questionId} {
          allow read: if isMember(groupId);
          allow write: if isAuth() && request.auth.uid == userId;
        }
      }
    }
  }
}
